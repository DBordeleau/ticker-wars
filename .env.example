# Ticker Wars local configuration

# Market data
# Current pipeline uses yfinance. No Alpha Vantage key is required.
MARKET_DATA_SOURCE=yfinance
START_DATE=2020-01-01
EXPORT_DIR=data_exports

# Supabase backend writes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-or-secret-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# React dashboard reads
# CRA reads these from frontend/.env* when running the frontend locally.
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
REACT_APP_SITE_URL=https://tickerwars.vercel.app
# Optional public URL containing dashboard JSON files from `python -m pipeline.cli export-snapshot`.
REACT_APP_DASHBOARD_SNAPSHOT_BASE_URL=https://cdn.example.com/dashboard

# Warren Buffbot toy LLM model
WARREN_BUFFBOT_ENABLED=false
LLM_PROVIDER=groq

# Gemini option
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Groq option
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional Hugging Face token
# Recommended for higher rate limits/faster model downloads when enabling TimesFM or Chronos.
HF_TOKEN=

# Optional Google TimesFM adapter
# Requires installing optional dependencies, for example: pip install -e ".[timesfm]"
TIMESFM_ENABLED=false
TIMESFM_MODEL_ID=google/timesfm-2.5-200m-pytorch
TIMESFM_CONTEXT_LENGTH=1024
TIMESFM_BACKEND=torch

# Optional Amazon Chronos-2 adapter
# Requires installing optional dependencies, for example: pip install -e ".[chronos]"
CHRONOS_ENABLED=false
CHRONOS_MODEL_ID=amazon/chronos-2
CHRONOS_CONTEXT_LENGTH=1024
CHRONOS_DEVICE_MAP=cpu
CHRONOS_FREQUENCY=B
